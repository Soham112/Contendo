# Required
ANTHROPIC_API_KEY=

# Optional — deployment
# Path to directory containing chroma_db/, posts.db, hierarchy.db, profile.json.
# Defaults to ./data (relative to the backend directory) when not set.
# On Railway: set to /data and mount the persistent volume at /data.
DATA_DIR=

# Exact origin of your deployed frontend, e.g. https://contendo.vercel.app
# Adds this origin to the CORS allow-list in addition to localhost:3000 and *.vercel.app.
FRONTEND_ORIGIN=

# Set to "production" in deployed environments.
# Controls Obsidian local-only route guard.
ENVIRONMENT=
