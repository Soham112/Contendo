# Supabase authentication (get these from your Supabase project settings)
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON=your_anon_key_from_supabase

# URL of the deployed backend API (no trailing slash)
# Local development: http://localhost:8000
# Production (Railway): https://your-service.up.railway.app
NEXT_PUBLIC_API_URL=http://localhost:8000
